{
  "expo": {
    "name": "GuardCircle",
    "slug": "GuardCircle",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF5E6"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.angelal1iii.guardcircle"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/icon.png"
      },
      "package": "com.angelaliii.guardcircle",
      "permissions": [
        "RECEIVE_SMS",
        "READ_SMS",
        "POST_NOTIFICATIONS",
        "INTERNET",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_SPECIAL_USE"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-notifications",
      "./plugins/withSmsInterceptor",
      [
        "expo-build-properties",
        {
          "android": {
            "toolsReplace": {
              "android:allowBackup": "true"
            }
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "400d1584-8901-4655-aa8f-11470331d22d"
      }
    }
  }
}
